        <button class="btn btn-ghost btn-sm" onclick="abrirFicha(${a.id})">Ficha</button>
        <button class="btn btn-acc btn-sm" onclick="abrirShAula(${a.id})">+ Aula</button>
        <button class="btn btn-red btn-sm" onclick="remAluno(${a.id})">✕</button>
