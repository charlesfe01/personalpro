<script>
const AVC=['av0','av1','av2','av3','av4','av5','av6'];
const DIAS=['seg','ter','qua','qui','sex','sab'];
const DIAS_L=['Seg','Ter','Qua','Qui','Sex','Sáb'];
const MESES=['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
const AV_CORES={'av0':'#3ecf8e','av1':'#4a9eff','av2':'#f5a623','av3':'#a76bff','av4':'#20c9c9','av5':'#ff6bb2','av6':'#ff5b5b'};
const AV_BG={'av0':'rgba(62,207,142,.2)','av1':'rgba(74,158,255,.2)','av2':'rgba(245,166,35,.2)','av3':'rgba(167,107,255,.2)','av4':'rgba(32,201,201,.2)','av5':'rgba(255,107,178,.2)','av6':'rgba(255,91,91,.2)'};
const SENHA_PERSONAL='personal123';
const BIN_ID='6a0b22a26877513b2790da71';
const BIN_KEY='$2a$10$78cpfiwda6cDJY2bKgVVouk7wCrJ7UqiXQRlAm0PxoCG36kQMU566';
const BIN_URL='https://api.jsonbin.io/v3/b/'+BIN_ID;

let alunos=JSON.parse(localStorage.getItem('pp5_al')||'[]');
let aulas=JSON.parse(localStorage.getItem('pp5_au')||'[]');
let nA=Math.max(0,...alunos.map(x=>x.id),0)+1;
let nAu=Math.max(0,...aulas.map(x=>x.id),0)+1;
let selDias=[],auId=null,rgAuId=null,rgAlId=null,diaAtual=null,pagEditId=null;
let cAno=new Date().getFullYear(),cMes=new Date().getMonth(),cDia=null;
let filtroAtual='todos',fotoB64=null;
let modoAtual=null;
let alunoLogado=null;
let alunoRgAuId=null;
let renovarId=null,alunoParaRemover=null;

function initDB(){
  fetch(BIN_URL+'/latest',{headers:{'X-Master-Key':BIN_KEY}})
    .then(r=>r.json())
    .then(j=>{
      if(j.record){
        const d=j.record;
        if(d.alunos) alunos=d.alunos;
        if(d.aulas) aulas=d.aulas;
        nA=Math.max(0,...alunos.map(x=>x.id),0)+1;
        nAu=Math.max(0,...aulas.map(x=>x.id),0)+1;
        localStorage.setItem('pp5_al',JSON.stringify(alunos));
        localStorage.setItem('pp5_au',JSON.stringify(aulas));
        if(modoAtual==='personal') renderAlunos();
        if(modoAtual==='aluno'&&alunoLogado){
          alunoLogado=alunos.find(x=>x.id===alunoLogado.id)||alunoLogado;
          if(document.getElementById('sc-aluno-home').classList.contains('active')) renderAlunoHome();
        }
      }
    }).catch(()=>{});
}

function save(){
  localStorage.setItem('pp5_al',JSON.stringify(alunos));
  localStorage.setItem('pp5_au',JSON.stringify(aulas));
  fetch(BIN_URL,{method:'PUT',headers:{'Content-Type':'application/json','X-Master-Key':BIN_KEY},body:JSON.stringify({alunos,aulas})}).catch(()=>{});
}
function ini(n){return n.trim().split(/\s+/).map(p=>p[0]).slice(0,2).join('').toUpperCase();}
function auAl(id){return aulas.filter(a=>a.alunoId===id);}
function rz(id){return aulas.filter(a=>a.alunoId===id&&a.status==='realizada').length;}
function agc(id){return aulas.filter(a=>a.alunoId===id&&a.status==='agendada').length;}
function ft(id){return aulas.filter(a=>a.alunoId===id&&a.status==='falta').length;}
function us(id){return aulas.filter(a=>a.alunoId===id&&(a.status==='realizada'||a.status==='agendada')).length;}
function pc(id,tot){return tot>0?Math.min(Math.round(us(id)/tot*100),100):0;}
function pcor(p){return p>=100?'var(--red)':p>=75?'var(--amber)':'var(--accent)';}
function fd(d){if(!d)return'—';const[y,m,dia]=d.split('-');return`${dia}/${m}`;}
function fdl(d){if(!d)return'—';const[y,m,dia]=d.split('-');return`${dia}/${m}/${y}`;}
function iso(y,m,d){return`${y}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;}
function avHtml(a,sz){sz=sz||42;return a.foto?`<div class="av ${a.av}" style="width:${sz}px;height:${sz}px;font-size:${Math.round(sz/3)}px"><img src="${a.foto}"></div>`:`<div class="av ${a.av}" style="width:${sz}px;height:${sz}px;font-size:${Math.round(sz/3)}px">${ini(a.nome)}</div>`;}
function gerarCodigo(nome){return nome.split(' ')[0].toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'')+Math.floor(100+Math.random()*900);}

function toast(msg,tipo){
  const e=document.getElementById('toast');e.textContent=msg;
  e.style.borderColor=tipo==='err'?'rgba(255,91,91,.3)':tipo==='warn'?'rgba(245,166,35,.3)':'rgba(255,255,255,.08)';
  e.classList.add('show');setTimeout(()=>e.classList.remove('show'),2500);
}
function openSh(id){document.getElementById(id).classList.add('open');}
function closeSh(id){document.getElementById(id).classList.remove('open');}
document.querySelectorAll('.overlay').forEach(el=>{el.addEventListener('click',e=>{if(e.target===el)el.classList.remove('open');});});

/* ══ LOGIN ══ */
function switchLoginTab(t){
  document.getElementById('ltab-personal').classList.toggle('active',t==='personal');
  document.getElementById('ltab-aluno').classList.toggle('active',t==='aluno');
  document.getElementById('login-personal-form').style.display=t==='personal'?'block':'none';
  document.getElementById('login-aluno-form').style.display=t==='aluno'?'block':'none';
}

function loginPersonal(){
  const s=document.getElementById('l-senha').value;
  if(s===SENHA_PERSONAL){
    modoAtual='personal';alunoLogado=null;
    document.getElementById('login-wrap').style.display='none';
    document.getElementById('app-main').style.display='flex';
    document.getElementById('topbar-user').textContent='Personal';
    buildNavbar('personal');
    showScreen('alunos');
    renderAlunos();
  } else {
    document.getElementById('l-err-personal').style.display='block';
  }
}

function loginAluno(){
  const cod=document.getElementById('l-codigo').value.trim().toLowerCase();
  const al=alunos.find(a=>a.codigo&&a.codigo.toLowerCase()===cod);
  if(al){
    modoAtual='aluno';alunoLogado=al;
    document.getElementById('login-wrap').style.display='none';
    document.getElementById('app-main').style.display='flex';
    document.getElementById('topbar-user').textContent=al.nome.split(' ')[0];
    buildNavbar('aluno');
    showScreen('aluno-home');
    renderAlunoHome();
  } else {
    document.getElementById('l-err-aluno').style.display='block';
  }
}

function logout(){
  modoAtual=null;alunoLogado=null;
  document.getElementById('app-main').style.display='none';
  document.getElementById('login-wrap').style.display='flex';
  document.getElementById('l-senha').value='';
  document.getElementById('l-codigo').value='';
  document.getElementById('l-err-personal').style.display='none';
  document.getElementById('l-err-aluno').style.display='none';
}

document.getElementById('l-senha').addEventListener('keydown',e=>{if(e.key==='Enter')loginPersonal();});
document.getElementById('l-codigo').addEventListener('keydown',e=>{if(e.key==='Enter')loginAluno();});

/* ══ NAVBAR ══ */
function buildNavbar(modo){
  const nb=document.getElementById('navbar');
  if(modo==='personal'){
    nb.innerHTML=`
      <button class="nb active" id="nb-alunos" onclick="showScreen('alunos')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="9" cy="7" r="3"/><path d="M3 21v-2a4 4 0 014-4h4a4 4 0 014 4v2"/><path d="M16 3.13a4 4 0 010 7.75"/><path d="M21 21v-2a4 4 0 00-3-3.87"/></svg>
        <span>Alunos</span>
      </button>
      <button class="nb" id="nb-agenda" onclick="showScreen('agenda')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/><circle cx="8" cy="15" r=".8" fill="currentColor"/><circle cx="12" cy="15" r=".8" fill="currentColor"/></svg>
        <span>Agenda</span>
      </button>
      <button class="nb" id="nb-financeiro" onclick="showScreen('financeiro');renderFinanceiro()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        <span>Financeiro</span>
      </button>
      <button class="nb" id="nb-resumo" onclick="showScreen('resumo')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
        <span>Resumo</span>
      </button>`;
  } else {
    nb.innerHTML=`
      <button class="nb active" id="nb-aluno-home" onclick="showScreen('aluno-home');renderAlunoHome()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <span>Início</span>
      </button>
      <button class="nb" id="nb-aluno-agendar" onclick="showScreen('aluno-agendar');renderAlunoAgendar()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18M12 15v4M10 17h4"/></svg>
        <span>Agendar</span>
      </button>
      <button class="nb" id="nb-aluno-hist" onclick="showScreen('aluno-hist');renderAlunoHist()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="9"/></svg>
        <span>Histórico</span>
      </button>`;
  }
}

function showScreen(n){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.nb').forEach(b=>b.classList.remove('active'));
  document.getElementById('sc-'+n).classList.add('active');
  const nb=document.getElementById('nb-'+n);
  if(nb)nb.classList.add('active');
  if(n==='agenda')renderCal();
  if(n==='resumo')renderResumo();
}

/* ══ PERSONAL: ALUNOS ══ */
function filtrar(f){
  filtroAtual=f;
  ['todos','fixo','avulso'].forEach(t=>document.getElementById('tab-'+t).classList.toggle('active',t===f));
  renderAlunos();
}
function toggleChip(el,d){el.classList.toggle('sel');selDias.includes(d)?selDias=selDias.filter(x=>x!==d):selDias.push(d);}
function toggleTipo(){document.getElementById('bloco-fixo').style.display=document.getElementById('a-tipo').value==='fixo'?'block':'none';}
function prevFoto(inp){if(!inp.files||!inp.files[0])return;const r=new FileReader();r.onload=e=>{fotoB64=e.target.result;const img=document.getElementById('foto-prev');img.src=fotoB64;img.style.display='block';document.getElementById('foto-txt').style.display='none';};r.readAsDataURL(inp.files[0]);}

function openShAluno(){
  selDias=[];fotoB64=null;
  document.querySelectorAll('#chips-dias .chip').forEach(c=>c.classList.remove('sel'));
  ['a-nome','a-tel','a-obs'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('a-total').value='12';
  document.getElementById('a-valor').value='';
  document.getElementById('a-pagstatus').value='pendente';
  document.getElementById('a-inicio').value=new Date().toISOString().split('T')[0];
  document.getElementById('a-tipo').value='fixo';document.getElementById('bloco-fixo').style.display='block';
  document.getElementById('foto-prev').style.display='none';document.getElementById('foto-txt').style.display='block';
  document.getElementById('a-codigo').value='';
  openSh('sh-aluno');
}

function salvarAluno(){
  const nome=document.getElementById('a-nome').value.trim();
  if(!nome){toast('Informe o nome','err');return;}
  const tipo=document.getElementById('a-tipo').value;
  if(tipo==='fixo'&&selDias.length===0){toast('Selecione ao menos um dia','err');return;}
  let codigo=document.getElementById('a-codigo').value.trim().toLowerCase();
  if(!codigo)codigo=gerarCodigo(nome);
  if(alunos.find(a=>a.codigo===codigo)){toast('Este código já existe, escolha outro','err');return;}
  alunos.push({id:nA++,nome,foto:fotoB64||null,tel:document.getElementById('a-tel').value.trim(),obj:document.getElementById('a-obj').value,obs:document.getElementById('a-obs').value.trim(),tipo,hora:tipo==='fixo'?document.getElementById('a-hora').value:null,dias:tipo==='fixo'?[...selDias]:[],av:AVC[(nA-1)%AVC.length],total:parseInt(document.getElementById('a-total').value)||12,valor:parseFloat(document.getElementById('a-valor').value)||0,pagStatus:document.getElementById('a-pagstatus').value||'pendente',inicio:document.getElementById('a-inicio').value,codigo});
  save();closeSh('sh-aluno');renderAlunos();toast('Aluno cadastrado! Código: '+codigo);
}

function remAluno(id){
  if(!confirm('Remover aluno e todas as aulas?'))return;
  alunos=alunos.filter(a=>a.id!==id);aulas=aulas.filter(a=>a.alunoId!==id);
  save();renderAlunos();toast('Removido');
}

function abrirWpp(tel,nome){
  if(!tel){toast('Telefone não cadastrado','warn');return;}
  window.open(`https://wa.me/55${tel.replace(/\D/g,'')}?text=${encodeURIComponent('Olá '+nome.split(' ')[0]+'!')}`,'_blank');
}

function renderAlunos(){
  const el=document.getElementById('lista');
  const lista=filtroAtual==='todos'?alunos:alunos.filter(a=>a.tipo===filtroAtual);
  if(!lista.length){el.innerHTML=`<div class="empty"><p>Nenhum aluno${filtroAtual!=='todos'?' '+filtroAtual:''}</p><span style="font-size:13px;color:var(--text3)">Toque em "+ Novo aluno"</span></div>`;return;}
  el.innerHTML=lista.map(a=>{
    const tot=a.total,u=us(a.id),r=rz(a.id),f=ft(a.id),rst=Math.max(tot-u,0),p=pc(a.id,tot),cor=pcor(p);
    const alerta=rst===1?`<div style="background:rgba(255,91,91,.1);border:1px solid rgba(255,91,91,.3);border-radius:8px;padding:7px 10px;font-size:12px;color:var(--red);margin:8px 0;animation:pulse 1.2s infinite">⚠ Última aula do pacote!</div>`:'';
    const sb=rst<=0?`<span class="badge br">Esgotado</span>`:rst===1?`<span class="badge br" style="animation:pulse 1.2s infinite">⚠ Última</span>`:`<span class="badge bg">${rst} restante${rst>1?'s':''}</span>`;
    const tb=a.tipo==='fixo'?`<span class="badge bb">Fixo</span>`:`<span class="badge bgr">Avulso</span>`;
    const dots=Array.from({length:Math.min(tot,20)},(_,i)=>i<r?`<div class="dot dok">✓</div>`:i<u?`<div class="dot dag">·</div>`:`<div class="dot dem">${i+1}</div>`).join('')+(tot>20?`<span style="font-size:10px;color:var(--text3)"> +${tot-20}</span>`:'');
    return`<div class="card">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
