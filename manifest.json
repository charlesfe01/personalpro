}

function abrirShAula(id){
  auId=id;const a=alunos.find(x=>x.id===id);
  document.getElementById('sh-aula-nome').textContent=a.nome;
  const rst=a.total-us(id);
  document.getElementById('sh-aula-av').innerHTML=rst<=0?`<div class="errb">Pacote esgotado.</div>`:rst===1?`<div class="errb">⚠ Última aula! Avise para renovar.</div>`:'';
  if(a.hora){const s=document.getElementById('au-hora');for(let i=0;i<s.options.length;i++)if(s.options[i].value===a.hora){s.selectedIndex=i;break;}}
  document.getElementById('au-data').value=new Date().toISOString().split('T')[0];
  document.getElementById('au-status').value='realizada';openSh('sh-aula');
}

function salvarAula(){
  const data=document.getElementById('au-data').value,hora=document.getElementById('au-hora').value,status=document.getElementById('au-status').value;
  if(!data){toast('Informe a data','err');return;}
  const a=alunos.find(x=>x.id===auId);
  if((status==='realizada'||status==='agendada')&&us(auId)>=a.total){if(!confirm('Pacote esgotado. Registrar mesmo assim?'))return;}
  aulas.push({id:nAu++,alunoId:auId,data,hora,status});
  save();closeSh('sh-aula');renderAlunos();
  if(document.getElementById('sc-agenda').classList.contains('active'))renderCal();
  toast(status==='realizada'?'Aula registrada!':status==='agendada'?'Agendada!':'Falta registrada');
}

function abrirFicha(id){
  const a=alunos.find(x=>x.id===id);
  const lista=auAl(id).sort((x,y)=>x.data.localeCompare(y.data));
  const r=rz(id),ag=agc(id),f=ft(id),u=us(id),rst=Math.max(a.total-u,0),p=pc(id,a.total),cor=pcor(p);
  const freq=r+f>0?Math.round(r/(r+f)*100):100;
  const dots=Array.from({length:a.total},(_,i)=>i<r?`<div class="dot dok">✓</div>`:i<u?`<div class="dot dag">·</div>`:`<div class="dot dem" style="font-size:8px">${i+1}</div>`).join('');
  const hist=lista.length===0?`<div style="color:var(--text3);font-size:13px;padding:8px 0">Nenhuma aula ainda</div>`:lista.map(au=>{
    const sc=au.status==='realizada'?'bg':au.status==='agendada'?'bb':'br';
    const sl=au.status==='realizada'?'Realizada':au.status==='agendada'?'Agendada':'Falta';
    return`<div class="aula-item">
      <div style="display:flex;align-items:center;justify-content:space-between">
        <div><div style="font-size:13px;font-weight:500;color:var(--text)">${fdl(au.data)}</div><div style="font-size:11px;color:var(--text2)">${au.hora}</div></div>
        <div style="display:flex;gap:5px;align-items:center"><span class="badge ${sc}">${sl}</span><button class="btn btn-red btn-sm" style="padding:3px 7px;font-size:11px" onclick="remAula(${au.id},${id})">✕</button></div>
      </div>
      ${au.status==='agendada'?`<button class="btn btn-blue btn-sm" style="width:100%;margin-top:6px" onclick="abrirReagendar(${au.id},${id})">↻ Reagendar</button>`:''}
    </div>`;
  }).join('');
  document.getElementById('ficha-content').innerHTML=`
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px">
      ${avHtml(a,50)}
      <div style="flex:1">
        <div style="font-size:17px;font-weight:600;color:var(--text)">${a.nome}</div>
        <div style="font-size:12px;color:var(--text2)">${a.obj} · ${a.tipo==='fixo'?'Fixo':'Avulso'}</div>
        <div style="font-size:12px;color:var(--text3);margin-top:2px">Código: <span style="color:var(--accent);font-weight:600">${a.codigo||'—'}</span></div>
      </div>
      ${a.tel?`<button class="wapp-btn" onclick="abrirWpp('${a.tel}','${a.nome}')"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>Zap</button>`:''}
    </div>
    ${a.obs?`<div class="infob" style="margin-bottom:10px">📋 ${a.obs}</div>`:''}
    <div class="stat2">
      <div class="sbox"><div class="sn" style="color:var(--accent)">${r}</div><div class="sl">Realizadas</div></div>
      <div class="sbox"><div class="sn" style="color:var(--blue)">${ag}</div><div class="sl">Agendadas</div></div>
      <div class="sbox"><div class="sn" style="color:${cor}">${rst}</div><div class="sl">Restantes</div></div>
      <div class="sbox"><div class="sn" style="color:var(--amber)">${freq}%</div><div class="sl">Frequência</div></div>
    </div>
    <div style="display:flex;justify-content:space-between;margin-bottom:2px">
      <span style="font-size:11px;color:var(--text2)">Pacote: ${a.total} aulas · ${u} usadas</span>
      <span style="font-size:11px;font-weight:600;color:${cor}">${p}%</span>
    </div>
    <div class="prog" style="margin-bottom:8px"><div class="pf" style="width:${p}%;background:${cor}"></div></div>
    <div class="dots" style="margin-bottom:12px">${dots}</div>
    <button class="btn btn-acc btn-full" style="margin-bottom:8px" onclick="closeSh('sh-ficha');abrirShAula(${id})">+ Registrar aula</button>
    <button class="btn btn-amber btn-sm btn-full" style="margin-bottom:12px" onclick="atualizarPagamento(${id})">$ Atualizar pagamento</button>
    <div class="divider"></div>
    <div style="font-size:12px;font-weight:600;color:var(--text2);margin-bottom:8px">Histórico</div>
    ${hist}
  `;
  openSh('sh-ficha');
}

function remAula(auId,alId){
  if(!confirm('Remover esta aula?'))return;
  aulas=aulas.filter(a=>a.id!==auId);save();abrirFicha(alId);renderAlunos();toast('Removida');
}

function abrirReagendar(auIdP,alIdP){
  rgAuId=auIdP;rgAlId=alIdP;
  const au=aulas.find(x=>x.id===auIdP);
  document.getElementById('sh-rg-titulo').textContent='Reagendar aula';
  document.getElementById('rg-data').value=au.data;
  const s=document.getElementById('rg-hora');for(let i=0;i<s.options.length;i++)if(s.options[i].value===au.hora){s.selectedIndex=i;break;}
  openSh('sh-reagendar');
}
function salvarReagendar(){
  const data=document.getElementById('rg-data').value,hora=document.getElementById('rg-hora').value;
  if(!data){toast('Informe a data','err');return;}
  const au=aulas.find(x=>x.id===rgAuId);au.data=data;au.hora=hora;
  save();closeSh('sh-reagendar');abrirFicha(rgAlId);renderAlunos();
  if(document.getElementById('sc-agenda').classList.contains('active'))renderCal();
  toast('Reagendada!');
}

/* ══ CALENDÁRIO ══ */
function mudaMes(d){cMes+=d;if(cMes>11){cMes=0;cAno++;}else if(cMes<0){cMes=11;cAno--;}renderCal();}

function renderCal(){
  const hISO=new Date().toISOString().split('T')[0];
  document.getElementById('cal-titulo').textContent=`${MESES[cMes]} ${cAno}`;
  const DOMS=['D','S','T','Q','Q','S','S'];
  let html=DOMS.map(d=>`<div class="cdow">${d}</div>`).join('');
  const prim=new Date(cAno,cMes,1).getDay(),ult=new Date(cAno,cMes+1,0).getDate(),ultAnt=new Date(cAno,cMes,0).getDate();
  for(let i=0;i<prim;i++)html+=`<div class="cday outro"><div class="cday-num">${ultAnt-prim+i+1}</div></div>`;
  for(let d=1;d<=ult;d++){
    const s=iso(cAno,cMes,d);
    const aulasNoDia=aulas.filter(a=>a.data===s).sort((a,b)=>a.hora.localeCompare(b.hora));
    const eh=s===hISO,es=s===cDia;
    let cls='cday';if(eh&&!es)cls+=' hoje';if(es)cls+=' sel';
    let bgStyle=aulasNoDia.length>0&&!es?'background:rgba(255,255,255,.04);color:var(--text);':'';
    const pills=aulasNoDia.slice(0,2).map(au=>{
      const al=alunos.find(x=>x.id===au.alunoId);if(!al)return'';
      const cor=AV_CORES[al.av]||'#3ecf8e',bg=AV_BG[al.av]||'rgba(62,207,142,.2)';
      return`<div class="cday-pill" style="background:${bg};color:${cor}">${au.hora} ${al.nome.split(' ')[0]}</div>`;
    }).join('');
    const mais=aulasNoDia.length>2?`<div class="cday-pill" style="background:rgba(255,255,255,.06);color:rgba(255,255,255,.4)">+${aulasNoDia.length-2}</div>`:'';
    html+=`<div class="${cls}" style="${bgStyle}" onclick="selDia('${s}')"><div class="cday-num">${d}</div><div class="cday-aulas">${pills}${mais}</div></div>`;
  }
  const resto=(7-(prim+ult)%7)%7;
  for(let i=1;i<=resto&&resto<7;i++)html+=`<div class="cday outro"><div class="cday-num">${i}</div></div>`;
  document.getElementById('calgrid').innerHTML=html;
  if(cDia)renderDia(cDia);
  else document.getElementById('dia-info').innerHTML='<div style="text-align:center;padding:14px;font-size:13px;color:var(--text3)">Toque em um dia para ver as aulas</div>';
}

function selDia(s){cDia=s;renderCal();}

function renderDia(s){
  const[y,m,d]=s.split('-'),titulo=`${parseInt(d)} de ${MESES[parseInt(m)-1]}`;
  const lista=aulas.filter(a=>a.data===s).sort((a,b)=>a.hora.localeCompare(b.hora));
  let html=`<div class="dia-title">${titulo}</div>`;
  if(!lista.length)html+=`<div style="font-size:12px;color:var(--text3);margin-bottom:8px">Nenhuma aula neste dia</div>`;
  lista.forEach(au=>{
    const al=alunos.find(x=>x.id===au.alunoId);if(!al)return;
    const sc=au.status==='realizada'?'var(--accent)':au.status==='agendada'?'var(--blue)':'var(--red)';
    const sl=au.status==='realizada'?'Realizada':au.status==='agendada'?'Agendada':'Falta';
    html+=`<div class="aula-row" onclick="abrirFicha(${al.id})">
      <span class="ahora">${au.hora}</span>${avHtml(al,30)}
      <div style="flex:1"><div style="font-size:13px;font-weight:500;color:var(--text)">${al.nome.split(' ')[0]}</div><div style="font-size:11px;color:var(--text2)">${al.tipo==='fixo'?'Fixo':'Avulso'}</div></div>
      <span style="font-size:11px;font-weight:500;color:${sc}">${sl}</span>
    </div>`;
  });
  html+=`<button class="add-dia" onclick="abrirShDia('${s}')">+ Adicionar aula neste dia</button>`;
  document.getElementById('dia-info').innerHTML=html;
}

function abrirShDia(s){
  diaAtual=s;const[y,m,d]=s.split('-');
  document.getElementById('sh-dia-titulo').textContent=`${parseInt(d)} de ${MESES[parseInt(m)-1]}`;
  if(!alunos.length){toast('Cadastre alunos primeiro','warn');return;}
  document.getElementById('ag-aluno').innerHTML=alunos.map(a=>`<option value="${a.id}">${a.nome}</option>`).join('');
  openSh('sh-dia');
}
function salvarAulaDia(){
  const alId=parseInt(document.getElementById('ag-aluno').value),hora=document.getElementById('ag-hora').value,status=document.getElementById('ag-status').value;
  const a=alunos.find(x=>x.id===alId);
  if((status==='realizada'||status==='agendada')&&us(alId)>=a.total){if(!confirm('Pacote esgotado. Registrar mesmo assim?'))return;}
  aulas.push({id:nAu++,alunoId:alId,data:diaAtual,hora,status});
  save();closeSh('sh-dia');renderCal();toast('Registrado!');
}

/* ══ FINANCEIRO ══ */
function renderFinanceiro(){
  const fmtV=v=>v&&v>0?`R$ ${parseFloat(v).toLocaleString('pt-BR',{minimumFractionDigits:2})}`:null;
  const pagos=alunos.filter(a=>a.pagStatus==='pago');
  const pendentes=alunos.filter(a=>!a.pagStatus||a.pagStatus==='pendente');
  const atrasados=alunos.filter(a=>a.pagStatus==='atrasado');
  const totalRecebido=pagos.reduce((s,a)=>s+(a.valor||0),0);
  const totalPendente=[...pendentes,...atrasados].reduce((s,a)=>s+(a.valor||0),0);

  document.getElementById('fin-stats').innerHTML=`
    <div class="sbox"><div class="sn" style="color:var(--accent);font-size:18px">${totalRecebido>0?fmtV(totalRecebido):'R$ 0'}</div><div class="sl">Recebido</div></div>
    <div class="sbox"><div class="sn" style="color:var(--amber);font-size:18px">${totalPendente>0?fmtV(totalPendente):'R$ 0'}</div><div class="sl">A receber</div></div>
    <div class="sbox"><div class="sn" style="color:var(--accent)">${pagos.length}</div><div class="sl">Pagos</div></div>
    <div class="sbox"><div class="sn" style="color:var(--red)">${atrasados.length}</div><div class="sl">Atrasados</div></div>
  `;

  if(!alunos.length){document.getElementById('fin-lista').innerHTML='<div class="empty"><p>Nenhum aluno cadastrado</p></div>';return;}

  // Separate by status
  const grupos=[
    {label:'⚠ Atrasados', lista:atrasados, cor:'var(--red)', cls:'br'},
    {label:'⏳ Pendentes', lista:pendentes, cor:'var(--amber)', cls:'ba'},
    {label:'✓ Pagos', lista:pagos, cor:'var(--accent)', cls:'bg'},
  ];

  let html='';
  grupos.forEach(g=>{
    if(!g.lista.length)return;
    html+=`<div style="font-size:12px;font-weight:600;color:var(--text2);margin:12px 0 6px">${g.label} (${g.lista.length})</div>`;
    html+=g.lista.map(a=>{
      const stLabel=a.pagStatus==='pago'?'Pago':a.pagStatus==='atrasado'?'Atrasado':'Pendente';
      return`<div class="card" style="padding:12px 14px">
        <div style="display:flex;align-items:center;gap:10px">
          ${avHtml(a,36)}
          <div style="flex:1;min-width:0">
            <div style="font-size:14px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${a.nome}</div>
            <div style="font-size:12px;color:var(--text2);margin-top:1px">${fmtV(a.valor)||'Sem valor definido'} · ${a.total} aulas</div>
          </div>
          <div style="display:flex;flex-direction:column;gap:6px;align-items:flex-end">
            <span class="badge ${g.cls}">${stLabel}</span>
            <button class="btn btn-ghost btn-sm" style="font-size:11px;padding:4px 10px" onclick="atualizarPagamento(${a.id})">Atualizar</button>
          </div>
        </div>
        ${a.pagStatus==='atrasado'?`<div style="background:rgba(255,91,91,.08);border-radius:7px;padding:6px 10px;font-size:11px;color:var(--red);margin-top:8px;display:flex;align-items:center;justify-content:space-between">⚠ Pagamento em atraso ${a.tel?`<button class="wapp-btn" style="font-size:11px;padding:4px 10px" onclick="abrirWpp('${a.tel}','${a.nome}')">Cobrar no Zap</button>`:''}  </div>`:''}
      </div>`;
    }).join('');
  });
  document.getElementById('fin-lista').innerHTML=html;
}

/* ══ RESUMO ══ */
function renderResumo(){
  const tR=aulas.filter(a=>a.status==='realizada').length;
  const tAg=aulas.filter(a=>a.status==='agendada').length;
  const tFt=aulas.filter(a=>a.status==='falta').length;
  const freq=tR+tFt>0?Math.round(tR/(tR+tFt)*100):0;
  document.getElementById('res-stats').innerHTML=`
    <div class="sbox"><div class="sn" style="color:var(--accent)">${tR}</div><div class="sl">Realizadas</div></div>
    <div class="sbox"><div class="sn" style="color:var(--blue)">${tAg}</div><div class="sl">Agendadas</div></div>
    <div class="sbox"><div class="sn" style="color:var(--red)">${tFt}</div><div class="sl">Faltas</div></div>
    <div class="sbox"><div class="sn" style="color:var(--amber)">${freq}%</div><div class="sl">Frequência</div></div>
  `;
  if(!alunos.length){document.getElementById('res-lista').innerHTML='<div class="empty"><p>Nenhum aluno</p></div>';return;}
  const sorted=[...alunos].sort((a,b)=>rz(b.id)-rz(a.id));
  document.getElementById('res-lista').innerHTML=`
    <div style="font-size:12px;font-weight:600;color:var(--text2);margin-bottom:8px">Ranking de frequência</div>
    ${sorted.map((a,idx)=>{
      const r=rz(a.id),f=ft(a.id),u=us(a.id),rst=Math.max(a.total-u,0),p=pc(a.id,a.total),cor=pcor(p);
      const fr=r+f>0?Math.round(r/(r+f)*100):100;
      const medal=idx===0?'🥇':idx===1?'🥈':idx===2?'🥉':`${idx+1}.`;
      const dots=Array.from({length:Math.min(a.total,16)},(_,i)=>i<r?`<div class="dot dok">✓</div>`:i<u?`<div class="dot dag">·</div>`:`<div class="dot dem" style="font-size:8px">${i+1}</div>`).join('')+(a.total>16?`<span style="font-size:10px;color:var(--text3)"> +${a.total-16}</span>`:'');
      return`<div class="card" style="cursor:pointer" onclick="abrirFicha(${a.id})">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
          ${avHtml(a,34)}
          <div style="flex:1"><div style="font-size:13px;font-weight:600;color:var(--text)">${medal} ${a.nome}</div>
          <div style="font-size:11px;color:var(--text2)">${r}/${a.total} aulas · freq. ${fr}% · ${rst} restantes</div></div>
          <span style="font-size:12px;font-weight:600;color:${cor}">${p}%</span>
        </div>
        <div class="prog"><div class="pf" style="width:${p}%;background:${cor}"></div></div>
        <div class="dots" style="margin-top:6px">${dots}</div>
      </div>`;
    }).join('')}`;
}

/* ══ MODO ALUNO ══ */
function renderAlunoHome(){
  const a=alunoLogado;
  // Atualiza dados do aluno (pode ter mudado)
  alunoLogado=alunos.find(x=>x.id===a.id)||a;
  const al=alunoLogado;
  const r=rz(al.id),ag=agc(al.id),f=ft(al.id),u=us(al.id),rst=Math.max(al.total-u,0),p=pc(al.id,al.total),cor=pcor(p);
  const alerta=rst===1?`<div class="errb" style="animation:pulse 1.2s infinite">⚠ Última aula do pacote! Fale com seu personal para renovar.</div>`:rst===0?`<div class="errb">Seu pacote está esgotado. Entre em contato para renovar.</div>`:'';
  const proximas=auAl(al.id).filter(x=>x.status==='agendada').sort((a,b)=>a.data.localeCompare(b.data)).slice(0,3);
  const proximasHtml=proximas.length===0?`<div style="font-size:13px;color:var(--text3);padding:8px 0">Nenhuma aula agendada</div>`:proximas.map(au=>`
    <div style="display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid var(--border)">
      <div style="background:rgba(74,158,255,.15);border-radius:8px;padding:6px 10px;text-align:center;flex-shrink:0">
        <div style="font-size:13px;font-weight:600;color:var(--blue)">${fd(au.data)}</div>
        <div style="font-size:11px;color:var(--text3)">${au.hora}</div>
      </div>
      <div style="flex:1"><div style="font-size:13px;font-weight:500;color:var(--text)">Aula agendada</div><div style="font-size:11px;color:var(--text2)">Toque para reagendar</div></div>
      <button class="btn btn-blue btn-sm" onclick="abrirReagendarAluno(${au.id})">↻</button>
    </div>`).join('');
  const dots=Array.from({length:al.total},(_,i)=>i<r?`<div class="dot dok">✓</div>`:i<u?`<div class="dot dag">·</div>`:`<div class="dot dem" style="font-size:8px">${i+1}</div>`).join('');
  const fmtV=v=>v&&v>0?`R$ ${parseFloat(v).toLocaleString('pt-BR',{minimumFractionDigits:2})}`:null;
  const pagSt=al.pagStatus||'pendente';
  const pagCor=pagSt==='pago'?'var(--accent)':pagSt==='atrasado'?'var(--red)':'var(--amber)';
  const pagLabel=pagSt==='pago'?'✓ Pago':pagSt==='atrasado'?'⚠ Atrasado':'Pendente';
  const pagIcon=pagSt==='pago'?'✓':pagSt==='atrasado'?'⚠':'⏳';
  const finCard=`<div class="card" style="margin-bottom:12px">
    <div style="font-size:14px;font-weight:600;margin-bottom:10px;color:var(--text)">💳 Financeiro</div>
    <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border)">
      <span style="font-size:13px;color:var(--text2)">Valor do pacote</span>
      <span style="font-size:14px;font-weight:600;color:var(--text)">${fmtV(al.valor)||'—'}</span>
    </div>
    <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0">
      <span style="font-size:13px;color:var(--text2)">Status do pagamento</span>
      <span style="font-size:13px;font-weight:600;color:${pagCor}">${pagLabel}</span>
    </div>
    ${pagSt==='atrasado'?`<div style="background:rgba(255,91,91,.08);border-radius:8px;padding:8px 10px;font-size:12px;color:var(--red);margin-top:4px">Entre em contato com seu personal para regularizar o pagamento.</div>`:''}
    ${pagSt==='pendente'?`<div style="background:rgba(245,166,35,.08);border-radius:8px;padding:8px 10px;font-size:12px;color:var(--amber);margin-top:4px">Pagamento pendente. Combine com seu personal a forma de pagamento.</div>`:''}
  </div>`;
  document.getElementById('aluno-home-content').innerHTML=`
    <div class="aluno-header">
      ${avHtml(al,50)}
      <div>
        <div style="font-size:18px;font-weight:600;color:var(--text)">Olá, ${al.nome.split(' ')[0]}! 👋</div>
        <div style="font-size:12px;color:var(--text2);margin-top:2px">${al.obj} · ${al.tipo==='fixo'?'Aluno fixo':'Aluno avulso'}</div>
      </div>
    </div>
    ${alerta}
    <div class="aluno-pacote">
      <div class="ap-box"><div class="ap-n" style="color:var(--accent)">${r}</div><div class="ap-l">Feitas</div></div>
      <div class="ap-box"><div class="ap-n" style="color:${cor}">${rst}</div><div class="ap-l">Restantes</div></div>
      <div class="ap-box"><div class="ap-n" style="color:var(--red)">${f}</div><div class="ap-l">Faltas</div></div>
    </div>
    <div style="display:flex;justify-content:space-between;margin-bottom:3px">
      <span style="font-size:12px;color:var(--text2)">Pacote: ${al.total} aulas · ${u} usadas</span>
      <span style="font-size:12px;font-weight:600;color:${cor}">${p}%</span>
    </div>
    <div class="prog" style="margin-bottom:10px"><div class="pf" style="width:${p}%;background:${cor}"></div></div>
    <div class="dots" style="margin-bottom:16px">${dots}</div>
    <div class="card">
      <div style="font-size:14px;font-weight:600;margin-bottom:4px;color:var(--text)">Próximas aulas</div>
      ${proximasHtml}
      <button class="btn btn-acc btn-full" style="margin-top:12px" onclick="showScreen('aluno-agendar');renderAlunoAgendar()">+ Agendar nova aula</button>
    </div>
  `;
}

function renderAlunoAgendar(){
  const al=alunoLogado;
  const u=us(al.id),rst=Math.max(al.total-u,0);
  const aviso=rst<=0?`<div class="errb">Seu pacote está esgotado. Fale com seu personal para renovar.</div>`:rst===1?`<div class="warn">⚠ Esta será sua última aula do pacote.</div>`:'';
  document.getElementById('aluno-agendar-content').innerHTML=`
    <div class="shdr"><span class="stitle">Agendar aula</span></div>
    ${aviso}
    <div class="card">
      <div style="font-size:13px;color:var(--text2);margin-bottom:14px">Escolha a data e o horário para sua próxima aula. Você tem <strong style="color:var(--accent)">${rst} aula${rst!==1?'s':''}</strong> restante${rst!==1?'s':''} no pacote.</div>
      <div class="fg"><label class="lbl">Data</label><input type="date" id="aluno-ag-data2" min="${new Date().toISOString().split('T')[0]}"></div>
      <div class="fg"><label class="lbl">Horário</label>
        <select id="aluno-ag-hora2">
          <option>05:00</option><option>06:00</option><option>07:00</option><option>08:00</option>
          <option>09:00</option><option>10:00</option><option>11:00</option><option>12:00</option>
          <option>13:00</option><option>14:00</option><option>15:00</option><option>22:00</option>
        </select>
      </div>
      ${al.hora?`<div style="font-size:12px;color:var(--text3);margin-bottom:10px">💡 Seu horário fixo é ${al.hora}</div>`:''}
      <button class="btn btn-acc btn-full" onclick="confirmarAgendamentoAluno()" ${rst<=0?'disabled style="opacity:.5"':''}>Confirmar agendamento</button>
    </div>
  `;
  if(al.hora){const s=document.getElementById('aluno-ag-hora2');if(s)for(let i=0;i<s.options.length;i++)if(s.options[i].value===al.hora){s.selectedIndex=i;break;}}
  document.getElementById('aluno-ag-data2').value=new Date().toISOString().split('T')[0];
}

function confirmarAgendamentoAluno(){
  const al=alunoLogado;
  const data=document.getElementById('aluno-ag-data2').value;
  const hora=document.getElementById('aluno-ag-hora2').value;
  if(!data){toast('Informe a data','err');return;}
  if(us(al.id)>=al.total){if(!confirm('Pacote esgotado. Agendar mesmo assim?'))return;}
  aulas.push({id:nAu++,alunoId:al.id,data,hora,status:'agendada',agendadoPeloAluno:true});
  save();
  toast('Aula agendada com sucesso!');
  showScreen('aluno-home');renderAlunoHome();
}

function salvarAgendamentoAluno(){confirmarAgendamentoAluno();}

function abrirReagendarAluno(auIdP){
  alunoRgAuId=auIdP;
  const au=aulas.find(x=>x.id===auIdP);
  document.getElementById('aluno-rg-data').value=au.data;
  const s=document.getElementById('aluno-rg-hora');for(let i=0;i<s.options.length;i++)if(s.options[i].value===au.hora){s.selectedIndex=i;break;}
  openSh('sh-aluno-reagendar');
}
function salvarReagendamentoAluno(){
  const data=document.getElementById('aluno-rg-data').value;
  const hora=document.getElementById('aluno-rg-hora').value;
  if(!data){toast('Informe a data','err');return;}
  const au=aulas.find(x=>x.id===alunoRgAuId);
  au.data=data;au.hora=hora;
  save();closeSh('sh-aluno-reagendar');renderAlunoHome();
  toast('Aula reagendada!');
}

function renderAlunoHist(){
  const al=alunoLogado;
  const lista=auAl(al.id).sort((a,b)=>b.data.localeCompare(a.data));
  const html=lista.length===0?`<div class="empty"><p>Nenhuma aula ainda</p></div>`:lista.map(au=>{
    const sc=au.status==='realizada'?'bg':au.status==='agendada'?'bb':'br';
    const sl=au.status==='realizada'?'Realizada ✓':au.status==='agendada'?'Agendada':'Falta';
    const agBy=au.agendadoPeloAluno?`<span style="font-size:10px;color:var(--text3)"> · por você</span>`:'';
    return`<div class="card" style="padding:12px 14px">
      <div style="display:flex;align-items:center;justify-content:space-between">
        <div>
          <div style="font-size:14px;font-weight:500;color:var(--text)">${fdl(au.data)}</div>
          <div style="font-size:12px;color:var(--text2);margin-top:2px">${au.hora}${agBy}</div>
        </div>
        <div style="display:flex;gap:6px;align-items:center">
          <span class="badge ${sc}">${sl}</span>
          ${au.status==='agendada'?`<button class="btn btn-blue btn-sm" onclick="abrirReagendarAluno(${au.id})">↻</button>`:''}
        </div>
      </div>
    </div>`;
  }).join('');
  document.getElementById('aluno-hist-content').innerHTML=`
    <div class="shdr"><span class="stitle">Histórico</span></div>
    ${html}
  `;
}

function atualizarPagamento(id){
  pagEditId=id;
  const a=alunos.find(x=>x.id===id);
  document.getElementById('sh-pag-titulo').textContent=`Pagamento — ${a.nome.split(' ')[0]}`;
  document.getElementById('pag-status-sel').value=a.pagStatus||'pendente';
  openSh('sh-pag-edit');
}
function salvarPagamento(){
  const a=alunos.find(x=>x.id===pagEditId);
  a.pagStatus=document.getElementById('pag-status-sel').value;
  save();closeSh('sh-pag-edit');closeSh('sh-ficha');renderAlunos();
  if(document.getElementById('sc-financeiro').classList.contains('active'))renderFinanceiro();
  toast('Pagamento atualizado!');
}

if('serviceWorker' in navigator)navigator.serviceWorker.register('./sw.js').catch(()=>{});
renderAlunos();
initDB();
</script>
</body>
</html>
